# Autopilot Environment Configuration
# Copy to .env and fill in your values

# Discord webhook for alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK

# PostgreSQL database URLs
DELE_DATABASE_URL=postgresql://user:pass@host:5432/dele_db
BIZSUITE_DATABASE_URL=postgresql://user:pass@host:5432/bizsuite_db

# AWS S3 for backups
S3_BACKUP_BUCKET=s3://your-backup-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# GPG encryption for backups (optional)
GPG_RECIPIENT=your-key-id

# Railway token (for restart commands)
RAILWAY_TOKEN=
